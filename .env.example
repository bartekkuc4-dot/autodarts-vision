# ── Environment variables for AutoDarts Vision ────────────────────────────────
#
# Copy this file to .env and fill in values as needed.
# .env is gitignored — never commit real secrets.
#
# For local Docker Compose usage, the defaults below work without changes.
# For cloud deployment (Hugging Face Spaces, etc.), override VITE_API_BASE.

# API base URL (Docker / nginx proxy — leave as /api for local deployment)
# For HF Spaces: set to https://your-space.hf.space
VITE_API_BASE=/api
